        <mxCell id="ent-mfc" value="&lt;b&gt;WMS/MFC connector pods x2&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;example budget: 300 req/hour*&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDEBF7;strokeColor=#2F75B5;fontSize=11;" vertex="1" parent="enterprise-adapter-layer"><mxGeometry x="905" y="65" width="295" height="65" as="geometry"/></mxCell>
