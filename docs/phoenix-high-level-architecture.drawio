        <!-- Editable minimum pod-count table -->
        <mxCell id="pod-count-table" value="&lt;b&gt;MINIMUM BASELINE POD COUNT BY LAYER&lt;/b&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;5&quot; cellspacing=&quot;0&quot; style=&quot;border-collapse:collapse;width:100%;font-size:11px&quot;&gt;&lt;tr style=&quot;background:#D9EAF7;font-weight:bold&quot;&gt;&lt;td&gt;Layer&lt;/td&gt;&lt;td&gt;Deployable workloads / replica basis&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;Minimum pods&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Enterprise connectors &amp;amp; rate limiters&lt;/td&gt;&lt;td&gt;RMS, R10/LDD, Stock Service, WMS/MFC, DHL, and Auto POS connectors x2&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;12&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Business logic &amp;amp; domain&lt;/td&gt;&lt;td&gt;13 service deployments x2 replicas; order ingestion owns canonical normalization and idempotency&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;26&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Kafka backbone&lt;/td&gt;&lt;td&gt;3 brokers + schema registry x2&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;5*&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Bidirectional seller channel adapters&lt;/td&gt;&lt;td&gt;10 channel adapters x2 + rate-aware scheduler x2; includes webhook and polling ingress&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;22&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Operations &amp;amp; observability&lt;/td&gt;&lt;td&gt;admin web x2 + admin API x2 + monitoring x2 + OTel x3&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;9&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;State / cache / evidence&lt;/td&gt;&lt;td&gt;PostgreSQL x2 + Redis ATS x3 + Redis cache x2 + log store x3&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;10*&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E2F0D9;font-weight:bold&quot;&gt;&lt;td&gt;Application total&lt;/td&gt;&lt;td&gt;Excludes Kafka and stateful platform services; Gateway/WAF is shared platform capacity&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;69&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF2CC;font-weight:bold&quot;&gt;&lt;td&gt;All self-hosted components&lt;/td&gt;&lt;td&gt;Application + Kafka + stateful services&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;84*&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;font style=&quot;font-size:10px&quot;&gt;* Platform-dependent: shared Kafka, PostgreSQL, Redis, object storage, or log services may not be project-owned pods. MFC 300 requests/hour is a planning example pending contract validation. Counts are HA launch baselines; HPA may add replicas but never bypass dependency quotas.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7F8C8D;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="1610" width="2120" height="275" as="geometry"/>
        </mxCell>
