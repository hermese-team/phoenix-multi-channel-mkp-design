        <mxCell id="reservation" value="&lt;b&gt;reservation-service&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Go pod | reserve / release ATS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2F0D9;strokeColor=#70AD47;fontSize=12;" vertex="1" parent="business-layer"><mxGeometry x="550" y="165" width="245" height="68" as="geometry"/></mxCell>
