        <mxCell id="legacy" value="&lt;b&gt;Legacy Marketplace&lt;/b&gt;&lt;br&gt;Parallel run / fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;" vertex="1" parent="external-layer"><mxGeometry x="1530" y="45" width="310" height="65" as="geometry"/></mxCell>

