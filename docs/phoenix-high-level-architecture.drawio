  <diagram id="phoenix-hla" name="Phoenix High-Level Architecture">
    <mxGraphModel dx="2200" dy="1900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;b&gt;Phoenix Multi-Channel Marketplace - High-Level Event-Driven Architecture&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:14px&quot;&gt;Provider-neutral | 50k orders/day forecast | 250 orders/s peak | Seller quota: 100 requests/min, bulk up to 100 items/request (not guaranteed)&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontColor=#17365D;" vertex="1" parent="1">
          <mxGeometry x="40" y="15" width="1850" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#1F4E78&quot;&gt;Blue/green = deployable pod&lt;/font&gt; | White = external system | Purple = event backbone | Cylinder = stateful data service | Dashed = telemetry/evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FC;strokeColor=#AAB7C4;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1900" y="15" width="260" height="62" as="geometry"/>
        </mxCell>

